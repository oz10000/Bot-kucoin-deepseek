# KuCoin API Credentials (usar sandbox para pruebas)
KUCOIN_API_KEY=tu_api_key
KUCOIN_API_SECRET=tu_api_secret
KUCOIN_API_PASSPHRASE=tu_passphrase

# Entorno: sandbox o live
KUCOIN_BASE_URL=https://openapi-sandbox.kucoin.com
# KUCOIN_BASE_URL=https://api.kucoin.com

# Símbolos a monitorear (separados por coma)
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT

# Timeframe para velas (ej. 1min, 3min, 5min, 15min)
TIMEFRAME=3min

# Intervalo de escaneo de señales (segundos)
SCAN_INTERVAL=60

# Parámetros de riesgo
RISK_PER_TRADE=0.01          # 1% del capital por operación
ATR_PERIOD=14
ATR_MULTIPLIER=1.5
TP_RATIO=0.3                 # 30% del edge para take profit
TRAILING_STOP_ACTIVATION=0.01 # 1% de ganancia para activar trailing
TRAILING_STOP_DISTANCE=0.005  # 0.5% de trailing

# Capital inicial (para calcular tamaño de posición)
INITIAL_CAPITAL=1000
